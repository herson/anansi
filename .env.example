# OpenAI API Key for AI Analysis (--ai flag)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# NVD API Key for CVE lookups (--cve flag) — optional but raises rate limit 5x
# Get your free key from: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Web Dashboard API Key — set this to protect the /scan and /api/status endpoints
ANANSI_API_KEY=
